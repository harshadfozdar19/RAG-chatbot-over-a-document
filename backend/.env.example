LLM_PROVIDER=openrouter
LLM_MODEL=openai/gpt-oss-20b:free

# Use Gemini for embeddings by default.
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDING_DIMENSION=768

GEMINI_API_KEY=replace_me

# Required only when LLM_PROVIDER=openrouter.
OPENROUTER_API_KEY=replace_me
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://your-frontend-domain.example
OPENROUTER_APP_NAME=RAG Chatbot

# Required only when LLM_PROVIDER=openai or EMBEDDING_PROVIDER=openai.
OPENAI_API_KEY=replace_me
OPENAI_BASE_URL=

PINECONE_API_KEY=replace_me
PINECONE_INDEX=rag-index-gemini
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

PORT=8000